{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "pull-request-title-pattern": "^(?<type>feat|fix|deps)(?<scope>\\([^)]+\\))?(?<breaking>!)?: (?<subject>.+)$",
  "packages": {
    ".": {
      "release-type": "simple",
      "prerelease": true,
      "prerelease-type": "rc",
      "version-file": "VERSION",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        {
          "type": "xml",
          "path": "ModbusDirectConnect.CLI/ModbusDirectConnect.CLI.csproj",
          "xpath": "//Project/PropertyGroup/Version"
        },
        {
          "type": "generic",
          "path": "PowerShell/ModbusDirectConnect.psd1"
        }
      ]
    }
  }
}
